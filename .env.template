# ============================================================
# Lingora Vendor Portal — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in all values before deploying.
# Never commit .env to version control.

# ── Database ─────────────────────────────────────────────────
# MySQL 8+ connection string.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# On Hostinger: create a MySQL database in hPanel → Databases
DATABASE_URL=mysql://USERNAME:PASSWORD@localhost:3306/lingora_portal

# ── JWT Secret ───────────────────────────────────────────────
# Used to sign all session cookies (admin + vendor).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ── Admin Setup Key ──────────────────────────────────────────
# One-time key used at /admin/setup to create the first admin account.
# Set to any strong random string. Keep it secret — remove or change after first use.
ADMIN_SETUP_KEY=REPLACE_WITH_STRONG_RANDOM_STRING

# ── Resend (Email Sending) ───────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# The "From" address for all outgoing emails.
# Must be on a domain you have verified in Resend.
RESEND_FROM_EMAIL=portal@lingora.tech
# Admin notification email — where vendor messages and alerts are sent.
ADMIN_NOTIFICATION_EMAIL=vm@lingoraloc.com

# ── Cloudflare R2 (File Storage) ─────────────────────────────
# Create a bucket at https://dash.cloudflare.com → R2 Object Storage
R2_ACCOUNT_ID=REPLACE_WITH_YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=REPLACE_WITH_YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=vp-storage
# Public URL for your R2 bucket (enable Public Access in bucket Settings)
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXX.r2.dev

# ── App Settings ─────────────────────────────────────────────
# The full public URL of your deployed portal (no trailing slash).
# Used for OAuth redirects and email links.
APP_URL=https://portal.lingoraloc.com

NODE_ENV=production
